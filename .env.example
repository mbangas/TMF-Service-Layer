# ─────────────────────────────────────────────────────────────────────────────
# TMF Service Layer — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tmf_db

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32-byte hex string — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-secure-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Application ───────────────────────────────────────────────────────────────
# Possible values: development | staging | production
APP_ENV=development
DEBUG=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to true to enforce JWT authentication (recommended for non-dev environments)
AUTH_ENABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array syntax)
CORS_ORIGINS=["http://localhost","http://localhost:8080","http://127.0.0.1:8080"]
